# QuantBridge — 환경 변수 (.env.example)
# 이 파일이 환경 변수의 Single Source of Truth (SSOT)
#
# === 사용법 ===
# 1. 이 파일을 `.env.local`로 복사
# 2. 아래 [필수] 마킹된 값을 실제 값으로 채움
# 3. 복사 위치:
#    - 로컬 uvicorn (cd backend && uv run uvicorn …):  backend/.env.local
#    - docker compose up:                               .env.local (repo root)
#    - Next.js dev (cd frontend && pnpm dev):           frontend/.env.local
#    (파일명이 동일하므로 각 디렉토리에 배포 필요. 아니면 repo root에 두고 심링크)
#
# === 범례 ===
# [필수 Sprint N]   : 해당 스프린트부터 실값 필요
# [선택]            : 기본값으로 동작, 고급 설정 시 변경
# [기본값 OK]       : 로컬 개발은 이 값 그대로 사용
# [자동]            : docker-compose가 자동 주입, 직접 편집 불필요

# =====================================================
# 앱 설정
# =====================================================
APP_NAME=QuantBridge
APP_ENV=development                    # development | staging | production
DEBUG=true
SECRET_KEY=dev-secret-change-in-prod   # [기본값 OK] 프로덕션만 실값 필요

# =====================================================
# Clerk 인증 (Sprint 3 ~)
# =====================================================
# 받는 곳: https://dashboard.clerk.com → 프로젝트 선택 → API Keys
#
# [Secret keys] 섹션 아래 "Secret key" 복사 — sk_test_로 시작
CLERK_SECRET_KEY=sk_test_PASTE_YOUR_SECRET_KEY_HERE  # [필수 Sprint 3]

# [Publishable keys] 섹션 아래 "Publishable key" — pk_test_로 시작
# 백엔드는 미사용. 프론트엔드 Clerk UI가 사용
CLERK_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_PUBLISHABLE_KEY_HERE          # [필수 Sprint 5 FE]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_PUBLISHABLE_KEY_HERE  # [필수 Sprint 5 FE] (동일값, Next.js 노출용)

# 받는 곳: Clerk Dashboard → Webhooks → Endpoints → (신규 엔드포인트 생성) → "Signing Secret"
# 형식: whsec_<base64 문자열>
# Sprint 3은 플레이스홀더로 충분 (테스트는 mock 서명 사용).
# 실값은 Sprint 7(배포) 때 공개 URL 등록 후 받음.
CLERK_WEBHOOK_SECRET=whsec_placeholder_sprint7_real_value              # [필수 Sprint 7] Sprint 3은 placeholder OK

# =====================================================
# 데이터베이스 (Sprint 3 ~)
# =====================================================
# PostgreSQL + TimescaleDB extension, docker-compose로 기동
# 테스트는 별도 DB `quantbridge_test` 사용 — pytest conftest가 DATABASE_URL 환경변수 우선
POSTGRES_USER=quantbridge                                              # [자동] docker-compose
POSTGRES_PASSWORD=password                                             # [자동] docker-compose 로컬 전용
POSTGRES_DB=quantbridge                                                # [자동] docker-compose

# 애플리케이션 접속 문자열 — docker compose 로컬 사용 시 그대로
DATABASE_URL=postgresql+asyncpg://quantbridge:password@localhost:5432/quantbridge  # [기본값 OK]

# TimescaleDB extension은 동일 DB의 `ts` schema에서 사용 (Sprint 5 M2~). 별도 URL 불필요.

# =====================================================
# Redis (Sprint 4부터 실제 사용, Celery 브로커 + 캐시)
# =====================================================
REDIS_URL=redis://localhost:6379/0                                     # [기본값 OK]
CELERY_BROKER_URL=redis://localhost:6379/1                             # [기본값 OK]
CELERY_RESULT_BACKEND=redis://localhost:6379/2                         # [기본값 OK]

# =====================================================
# Backtest (Sprint 4)
# =====================================================
BACKTEST_STALE_THRESHOLD_SECONDS=1800                                  # [기본값 OK]
OHLCV_FIXTURE_ROOT=backend/data/fixtures/ohlcv                         # [기본값 OK]

# =====================================================
# Sprint 6 Trading
# =====================================================
# Fernet 마스터 키들 (comma-separated, 최신순). MultiFernet 기반.
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# rotation 시 새 키를 맨 앞에 추가, 구키는 grace 기간 후 제거.
# autoplan CEO F3 + Eng E4 반영.
# 로컬 dev 최단경로:
#   python -c "from cryptography.fernet import Fernet; print(f'TRADING_ENCRYPTION_KEYS={Fernet.generate_key().decode()}')" >> .env.local
TRADING_ENCRYPTION_KEYS=                                               # [필수 Sprint 6]
# Exchange provider: fixture (테스트) | bybit_demo (Spot testnet) | bybit_futures (Linear Perp testnet, Sprint 7a)
EXCHANGE_PROVIDER=fixture                                              # [기본값 OK]
# Sprint 7a: OrderRequest.leverage 상한 (이론 125x, 리스크 관리로 기본 20x)
BYBIT_FUTURES_MAX_LEVERAGE=20                                          # [기본값 OK]
# Kill Switch thresholds (Decimal)
KILL_SWITCH_CUMULATIVE_LOSS_PERCENT=10.0                               # [기본값 OK]
KILL_SWITCH_DAILY_LOSS_USD=500.0                                       # [기본값 OK]
KILL_SWITCH_API_ERROR_STREAK=5                                         # [기본값 OK]
# capital base for cumulative loss calc — Sprint 6은 config, Sprint 7은 ExchangeAccount.fetch_balance()
KILL_SWITCH_CAPITAL_BASE_USD=10000                                     # [기본값 OK]
# Webhook secret rotation grace period (초)
WEBHOOK_SECRET_GRACE_SECONDS=3600                                      # [기본값 OK]

# =====================================================
# CORS / URL
# =====================================================
FRONTEND_URL=http://localhost:3000                                     # [기본값 OK]
NEXT_PUBLIC_API_URL=http://localhost:8000                              # [기본값 OK]
NEXT_PUBLIC_WS_URL=ws://localhost:8000                                 # [기본값 OK]

# =====================================================
# 거래소 (Sprint ~ 거래소 연동 시)
# =====================================================
DEFAULT_EXCHANGE=bybit                                                 # [기본값 OK]
OHLCV_PROVIDER=fixture                                                 # [기본값 OK] fixture | timescale (Sprint 5 M3+)
