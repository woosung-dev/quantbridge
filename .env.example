# QuantBridge — 환경 변수 (.env.example)
# 이 파일이 환경 변수의 Single Source of Truth (SSOT)
# .env.local에 복사하여 실제 값을 채워 사용

# === 앱 설정 ===
APP_NAME=QuantBridge
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# === Clerk 인증 ===
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# === 데이터베이스 (PostgreSQL + TimescaleDB extension, 단일 인스턴스) ===
# docker-compose가 POSTGRES_* 로 컨테이너를 초기화하고, 앱은 DATABASE_URL 로 접속
POSTGRES_USER=quantbridge
POSTGRES_PASSWORD=password
POSTGRES_DB=quantbridge
DATABASE_URL=postgresql+asyncpg://quantbridge:password@localhost:5432/quantbridge

# TimescaleDB는 DATABASE_URL과 동일 인스턴스의 extension으로 동작 (OHLCV는 hypertable)
# 별도 URL이 필요한 경우(읽기 전용 복제본 등)에만 오버라이드
TIMESCALE_URL=${DATABASE_URL}

# === Redis (캐시 + Celery 브로커) ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === 암호화 (거래소 API Key AES-256 암호화용) ===
ENCRYPTION_KEY=your-aes-256-encryption-key

# === CORS ===
FRONTEND_URL=http://localhost:3000

# === 거래소 기본 설정 ===
DEFAULT_EXCHANGE=bybit

# === API URL (Frontend → Backend) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
