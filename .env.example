# QuantBridge — 환경 변수 (.env.example)
# 이 파일이 환경 변수의 Single Source of Truth (SSOT)
# .env.local에 복사하여 실제 값을 채워 사용

# === 앱 설정 ===
APP_NAME=QuantBridge
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# === Clerk 인증 ===
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# === 데이터베이스 (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://quantbridge:password@db:5432/quantbridge

# === 시계열 DB (TimescaleDB) ===
TIMESCALE_URL=postgresql+asyncpg://quantbridge:password@timescaledb:5432/quantbridge_ts

# === Redis (캐시 + Celery 브로커) ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === 암호화 (거래소 API Key AES-256 암호화용) ===
ENCRYPTION_KEY=your-aes-256-encryption-key

# === CORS ===
FRONTEND_URL=http://localhost:3000

# === 거래소 기본 설정 ===
DEFAULT_EXCHANGE=bybit

# === API URL (Frontend → Backend) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
