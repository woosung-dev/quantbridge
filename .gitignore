# === Playwright MCP ad-hoc evidence (root) ===
# dogfood / smoke 스크린샷 — repo root 무시
# (codex G.2 P1 #2: docs/dev-log/screenshots/ 은 예외 — 리뷰어 재현 가능)
sprint*-day*-*.png
sprint*-day*-*.jpeg
!docs/dev-log/screenshots/**

# === AI tooling ===
.ai/
# .claude/ 하위는 전체 무시하되 settings.json만 예외 (팀 공유 baseline)
.claude/*
!.claude/settings.json
# .claude/settings.local.json (개인 override)은 위 .claude/* 규칙으로 자동 무시됨
.agents/
# .gstack/ 는 gstack skill 임시 산출물 전반 무시. experiments/ 는 실측 자산이라 예외.
.gstack/*
!.gstack/experiments/
.gstack/experiments/**/.venv/
.gstack/experiments/**/workdir/
.gstack/experiments/**/__pycache__/
.gstack/experiments/**/*.py[cod]

# === 환경 변수 ===
.env
.env.local
.env.*.local
.env.demo
!.env.example

