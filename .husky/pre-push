# Sprint FE-01 LESSON-004: push 전에 FE 타입체크 + 테스트로 회귀 방어.
# Sprint 33 (codex G.0 P1-1): main worktree push 차단 (worker isolation 영구).
# 로컬에서 무한 루프 / 타입 에러 / 테스트 실패 코드가 원격에 올라가기 전에 차단.
# 스킵하려면 --no-verify (단, PR이 올라가면 CI에서 다시 검사됨)

# stash 없이 현재 staged/working tree 상태 그대로 검증
set -e

# Sprint 33 (codex P1-1): main worktree push 차단 (자율 병렬 worker isolation 영구)
# main worktree = git_dir == git_common_dir. worker worktree = 별 .git dir (linked).
#
# Sprint 37 개선: branch-prefix 기반 화이트리스트.
# - main/master 직접 push = 영구 금지 (PR-only 정책, bypass 도 차단)
# - feat/* | fix/* | chore/* | docs/* | test/* | refactor/* | hotfix/* = 메인 세션 의도 추정 → 허용
# - 그 외 임의 branch (worker 일 가능성) = 차단 + bypass 안내
QB_GIT_DIR="$(git rev-parse --git-dir)"
QB_GIT_COMMON_DIR="$(git rev-parse --git-common-dir)"
QB_REPO_ROOT="$(git rev-parse --show-toplevel)"
QB_BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || echo unknown)"
if [ "$QB_GIT_DIR" = "$QB_GIT_COMMON_DIR" ]; then
  case "$QB_BRANCH" in
    main|master)
      # main 직접 push 영구 금지 (bypass 도 차단)
      echo "ERROR: main 직접 push 영구 금지 — PR 경유 의무"
      echo "  branch: $QB_BRANCH"
      echo "  path: $QB_REPO_ROOT"
      exit 1
      ;;
    feat/*|fix/*|chore/*|docs/*|test/*|refactor/*|hotfix/*)
      # feature branch = 메인 세션 의도 추정 → 허용
      echo "→ pre-push: main worktree, feature branch ($QB_BRANCH) — 허용"
      ;;
    *)
      # 임의 branch (worker 일 가능성) → 차단 + bypass 안내
      if [ "$QB_PRE_PUSH_BYPASS" = "1" ]; then
        echo "→ pre-push: BYPASS — main worktree 임의 branch push 허용 (QB_PRE_PUSH_BYPASS=1)"
        echo "  branch: $QB_BRANCH"
        echo "  path: $QB_REPO_ROOT"
      else
        echo "ERROR: main worktree + 임의 branch push 차단 (Sprint 33 worker isolation)"
        echo "  branch: $QB_BRANCH"
        echo "  path: $QB_REPO_ROOT"
        echo ""
        echo "  표준 prefix (feat/fix/chore/docs/test/refactor/hotfix) 사용 권장."
        echo "  의도적 임의 branch push 시: QB_PRE_PUSH_BYPASS=1 git push <args>"
        exit 1
      fi
      ;;
  esac
else
  echo "→ pre-push: worker worktree (path: $QB_REPO_ROOT)"
fi

# @{u} 없으면(첫 push) origin/main 으로 폴백
# LESSON: 첫 push 시 @{u} 미존재 → 2>/dev/null silently 실패 → diff 빈 출력 → 검사 스킵 버그
if git rev-parse @{u} >/dev/null 2>&1; then
  QB_DIFF_BASE="@{u}"
else
  QB_DIFF_BASE="origin/main"
fi

# FE 변경이 있을 때만 FE 검사 실행
if git diff --name-only "$QB_DIFF_BASE".. 2>/dev/null | grep -q '^frontend/'; then
  echo "→ pre-push: frontend typecheck + test (hooks 안전 방어선)"
  cd frontend
  pnpm typecheck
  pnpm test
  cd -
else
  echo "→ pre-push: frontend 변경 없음, 스킵"
fi

# BE 변경이 있을 때만 BE 검사 실행
# BL-239 (Sprint 56): pre-push hook 안 mypy 추가 — CI parity gap 해소.
# BL-240 (Sprint 56): backend/.env.local 의 TEST_* 변수만 자동 source — LESSON-061 영구 fix.
#   운영 secret (DATABASE_URL, SECRET_KEY 등) 은 export 안 함. test 전용 prefix 만 hook scope 안 활성.
if git diff --name-only "$QB_DIFF_BASE".. 2>/dev/null | grep -q '^backend/'; then
  echo "→ pre-push: backend ruff + mypy + pytest"

  # BL-240: backend/.env.local 의 TEST_* 변수만 auto-source (LESSON-061 영구 fix).
  # husky pre-push = sh (bash X). process substitution `<()` 사용 불가 → 임시 파일 경유.
  # `^TEST_<KEY>=value` 패턴만 추출 → set -a + . source → 운영 secret (DATABASE_URL,
  # SECRET_KEY 등 non-TEST prefix) 차단. hook 종료 시 shell context 소멸 = scope 격리.
  QB_ENV_FILE="$QB_REPO_ROOT/backend/.env.local"
  if [ -f "$QB_ENV_FILE" ]; then
    QB_TMP_ENV=$(mktemp)
    grep -E "^TEST_[A-Z_]+=" "$QB_ENV_FILE" > "$QB_TMP_ENV" 2>/dev/null || true
    if [ -s "$QB_TMP_ENV" ]; then
      set -a
      . "$QB_TMP_ENV"
      set +a
      echo "  → BL-240 auto-source: backend/.env.local 의 TEST_* 변수 export 완료"
    fi
    rm -f "$QB_TMP_ENV"
  fi

  cd backend
  uv run ruff check .
  uv run mypy src/
  uv run pytest -q
  cd -
else
  echo "→ pre-push: backend 변경 없음, 스킵"
fi
