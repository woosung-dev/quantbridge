{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "QuantBridge Claude Code 공유 permission baseline. 개인 override는 .claude/settings.local.json 참조.",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(docker ps*)",
      "Bash(docker compose*)",
      "Bash(docker start*)",
      "Bash(docker stop*)",
      "Bash(docker logs*)",
      "Bash(cat*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(cd backend && uv run*)",
      "Bash(cd frontend && pnpm*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr create*)",
      "Bash(gh pr list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh api*)",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push*)",
      "Bash(gh pr merge*)",
      "Bash(docker rm*)",
      "Bash(docker volume rm*)",
      "Bash(docker system prune*)",
      "Bash(docker image prune*)",
      "Bash(sudo*)"
    ]
  }
}
