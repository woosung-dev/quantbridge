# QuantBridge — Frontend `.env.example` (Next.js dev/build)
#
# === 로드 주체 ===
# 이 파일을 `cp .env.example .env.local`로 복사.
# Next.js는 `.env.local` > `.env.development` > `.env`를 자동 로드.
# 대상 명령: `cd frontend && pnpm dev` / `pnpm build`
#
# === NEXT_PUBLIC_ 프리픽스 ===
# NEXT_PUBLIC_ 접두사가 붙은 변수만 클라이언트 번들에 노출됨.
# 시크릿 값은 절대 NEXT_PUBLIC_에 넣지 말 것 (GitHub leak 위험).
#
# === 다른 서비스 env 위치 ===
# - Backend uvicorn:    ../backend/.env.local
# - Docker compose:     ../.env (root)

# =====================================================
# Clerk 인증 (Sprint 5 FE+)
# =====================================================
# Clerk Dashboard → API Keys → Publishable keys 에서 복사 (pk_test_ 접두사).
# 공개 키이므로 번들 노출 안전. 동일 값이 root/.env의 CLERK_PUBLISHABLE_KEY(backend dev)와 정합해야 Clerk 인증 일관.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_PUBLISHABLE_KEY_HERE   # [필수 Sprint 5 FE+]

# Sprint 61 T-3 (BL-319): Clerk sign-in/up/out URL 명시. 미설정 시 dev instance 가
# accounts.dev (Clerk Hosted Pages) 로 redirect → 잠재 고객 신뢰 손실. 자체 도메인
# 안에서만 인증 흐름 유지.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in                                     # [기본값 OK]
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up                                     # [기본값 OK]
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/strategies                # [기본값 OK]
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/strategies                # [기본값 OK]

# =====================================================
# Backend API URL
# =====================================================
# 로컬 개발: uvicorn localhost:8000. 프로덕션: 배포 URL.
NEXT_PUBLIC_API_URL=http://localhost:8000                              # [기본값 OK]
NEXT_PUBLIC_WS_URL=ws://localhost:8000                                 # [기본값 OK] WebSocket (실시간 데이터)
# Sprint 60 S3 BL-268 — Webhook base URL (외부 TradingView 호출용 production endpoint)
# 미설정 시 NEXT_PUBLIC_API_URL fallback (dev 환경, 외부 호출 불가)
NEXT_PUBLIC_WEBHOOK_BASE_URL=                                          # [optional] 예: https://hooks.quantbridge.app

# =====================================================
# Sprint 13 Phase B: Test Order Dialog (dogfood-only)
# =====================================================
# /trading 페이지에서 browser-side HMAC 서명으로 webhook 직접 발송하는 dogfood 도구.
# Production 은 false 또는 미설정 — 사용자가 webhook secret 노출 위험.
NEXT_PUBLIC_ENABLE_TEST_ORDER=true                                     # [dogfood 전용]

# =====================================================
# Sprint 25: Playwright E2E (Clerk Testing) — local-only, dev-only
# =====================================================
# `@clerk/testing` 의 `clerkSetup() + clerk.signIn()` 공식 패턴 prereq.
# `pnpm e2e:authed` (NODE_ENV !== production guard) 가 의도한 곳에서만 사용.
# 4 변수 모두 `.env.local` (gitignored) 에만 입력. `.env.example` 은 placeholder.
#
# CLERK_PUBLISHABLE_KEY / CLERK_SECRET_KEY 는 NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY 와
# 별도 env (test runner 용 — Testing Token 발급 + signIn 자동화).
# Clerk Dashboard → API Keys → Publishable + Secret (pk_test_ / sk_test_).
CLERK_PUBLISHABLE_KEY=pk_test_PASTE_HERE                               # [Sprint 25 e2e:authed prereq]
CLERK_SECRET_KEY=sk_test_PASTE_HERE                                    # [Sprint 25 e2e:authed prereq]

# E2E 자동 sign-in 시 사용. Clerk Dashboard → Users 에서 dev 계정 1개 생성 후 입력.
# `.env.local` 에만 입력. production 에서는 절대 사용 안 함.
E2E_CLERK_USER_EMAIL=test@dogfood.local                                # [Sprint 25 e2e:authed prereq]
E2E_CLERK_USER_PASSWORD=PASTE_PASSWORD_HERE                            # [Sprint 25 e2e:authed prereq]
